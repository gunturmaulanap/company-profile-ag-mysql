# App
NODE_ENV="development"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace-with-strong-random-secret"

# MySQL (requested format)
DB_CONNECTION="mysql"
DB_HOST="127.0.0.1"
DB_PORT="3306"
DB_DATABASE="db_adibayu_compro"
DB_USERNAME="root"
DB_PASSWORD=""

# Prisma requires DATABASE_URL.
DATABASE_URL="mysql://root:@127.0.0.1:3306/db_adibayu_compro"

# Existing project env
APP_URL="MY_APP_URL"

# Contact form email delivery (Resend)
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxx"
SENDGRID_API_KEY="SG.xxxxxxxxxxxxxxxxxxxxxxxxx"
CONTACT_FROM_EMAIL="no-reply@adibayu.com"
CONTACT_TO_EMAIL="office@adibayu.com"

SENDGRID_API_KEY=""
CONTACT_FROM_EMAIL="no-reply@adibayu.com"
CONTACT_TO_EMAIL="office@adibayu.com"

# reCAPTCHA
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""

